# Copy to .env.local and fill in values. Nunca commits la copia con datos reales.

# --- Público (bundle del cliente) -----------------------------------------
# Se usa únicamente en el checkout client-side (Stripe Elements).
NEXT_PUBLIC_API_GRAPHQL_URL=http://localhost:3001/graphql
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Server-only (jamás exponer al cliente) -------------------------------
# URL server-side del API (puede diferir del público en prod: red privada, etc.)
API_GRAPHQL_URL=http://localhost:3001/graphql

# Secreto compartido con el API (bienbravo-api). El API lo reconoce en el header
# `x-service-token` y construye un viewer `SERVICE` con permisos readonly de
# catálogo/sucursales/stock. Genera con: openssl rand -hex 32
API_SERVICE_TOKEN=

# HMAC para firmar el webhook /api/revalidate que el admin dispara al publicar
# cambios (nuevo producto, precio, stock). Genera con: openssl rand -hex 32
REVALIDATE_SECRET=
